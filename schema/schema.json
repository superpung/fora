{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://conf-scheduler/schema/conference.json",
  "title": "Conference Agenda (self-designed)",
  "description": "本项目自建的会议议程通用模型。不兼容/不映射任何现成格式(pretalx/frab/pentabarf)，完全依据真实会议(CCF Chip 2026)的结构设计。核心：会议→天→时段块→论坛→报告 的多层结构；论坛为一等实体；报告允许无独立时间；广泛支持双语与TBD状态。",
  "type": "object",
  "required": ["id", "name", "start_date", "end_date"],
  "properties": {
    "id": { "type": "string", "description": "会议唯一短标识，如 ccfchip2026" },
    "source_url": { "type": "string" },
    "name": { "$ref": "#/$defs/i18n", "description": "会议名称（中英）" },
    "edition": { "type": "string", "description": "届次，如 第三届" },
    "start_date": { "type": "string", "format": "date" },
    "end_date": { "type": "string", "format": "date" },
    "timezone": { "type": "string", "default": "Asia/Shanghai" },
    "contact": {
      "type": "object",
      "properties": { "email": { "type": "string" } },
      "additionalProperties": true
    },
    "links": {
      "type": "object",
      "description": "官网/注册/酒店等入口",
      "additionalProperties": { "type": "string" }
    },
    "venues": { "type": "array", "items": { "$ref": "#/$defs/venue" } },
    "organizations": { "type": "array", "items": { "$ref": "#/$defs/organization" } },
    "committees": { "type": "array", "items": { "$ref": "#/$defs/committee" } },
    "days": { "type": "array", "items": { "$ref": "#/$defs/day" } },
    "forums": {
      "type": "array",
      "description": "所有技术论坛（一等实体）。schedule 中的 forum_block 通过 code 引用它们。",
      "items": { "$ref": "#/$defs/forum" }
    },
    "extraction": { "$ref": "#/$defs/extraction_meta" }
  },
  "additionalProperties": false,

  "$defs": {
    "i18n": {
      "description": "双语文本；zh 必填，en 可选。",
      "type": "object",
      "required": ["zh"],
      "properties": {
        "zh": { "type": "string" },
        "en": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },

    "status": {
      "description": "字段确定状态：confirmed=已定；tbd=待定(源标注如“待确认/待定”)；unknown=源未提供。",
      "type": "string",
      "enum": ["confirmed", "tbd", "unknown"]
    },

    "asset": {
      "description": "本地已下载的资源引用。",
      "type": "object",
      "properties": {
        "local_path": { "type": ["string", "null"] },
        "source_url": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },

    "venue": {
      "type": "object",
      "required": ["id", "name"],
      "properties": {
        "id": { "type": "string" },
        "name": { "$ref": "#/$defs/i18n" },
        "type": { "type": "string", "enum": ["main", "hotel", "other"], "default": "main" },
        "city": { "type": "string" },
        "note": { "type": "string" }
      },
      "additionalProperties": false
    },

    "organization": {
      "description": "主办/承办/协办/赞助单位。",
      "type": "object",
      "required": ["name", "role"],
      "properties": {
        "name": { "$ref": "#/$defs/i18n" },
        "role": { "type": "string", "enum": ["host", "co_host", "support", "sponsor"] },
        "sponsor_tier": { "type": ["string", "null"], "description": "赞助档位，如 金钻/钻石/铂金/黄金/白银" },
        "logo": { "$ref": "#/$defs/asset" }
      },
      "additionalProperties": false
    },

    "person": {
      "description": "人物。affiliation_raw 保留源上的“单位+职称”原文；可选拆解为结构化字段。",
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string" },
        "name_en": { "type": ["string", "null"] },
        "affiliation_raw": { "type": ["string", "null"], "description": "如 “南京邮电大学 教授”“中国科学院院士 深圳大学讲席教授”" },
        "organization": { "type": ["string", "null"] },
        "title": { "type": ["string", "null"], "description": "职称，如 教授/研究员/CEO" },
        "honorifics": { "type": "array", "items": { "type": "string" }, "description": "如 院士/IEEE Fellow" },
        "photo": { "$ref": "#/$defs/asset" },
        "bio": { "type": ["string", "null"] },
        "chair_role": { "type": ["string", "null"], "description": "当作为论坛主席时的角色，如 论坛主席/共同主席" }
      },
      "additionalProperties": false
    },

    "committee": {
      "description": "一个委员会/角色组，如 大会主席、程序委员会主席、大会指导委员会。",
      "type": "object",
      "required": ["role", "members"],
      "properties": {
        "role": { "$ref": "#/$defs/i18n" },
        "ordering_note": { "type": ["string", "null"], "description": "如 “按拼音排序”" },
        "members": { "type": "array", "items": { "$ref": "#/$defs/person" } }
      },
      "additionalProperties": false
    },

    "day": {
      "type": "object",
      "required": ["date", "blocks"],
      "properties": {
        "date": { "type": "string", "format": "date" },
        "venue_id": { "type": ["string", "null"] },
        "overview": {
          "description": "总览矩阵里该天 上午/下午/晚上 的粗粒度标签（展示用，冗余可推导）。",
          "type": "object",
          "properties": {
            "morning": { "type": "array", "items": { "type": "string" } },
            "afternoon": { "type": "array", "items": { "type": "string" } },
            "evening": { "type": "array", "items": { "type": "string" } }
          },
          "additionalProperties": false
        },
        "blocks": { "type": "array", "items": { "$ref": "#/$defs/block" } }
      },
      "additionalProperties": false
    },

    "block": {
      "description": "一天内的一个时段块。kind 决定其载荷字段。",
      "type": "object",
      "required": ["kind"],
      "properties": {
        "id": { "type": "string" },
        "kind": {
          "type": "string",
          "enum": ["registration", "keynotes", "forums", "break", "banquet", "committee_meetings", "other"]
        },
        "title": { "$ref": "#/$defs/i18n" },
        "start": { "type": ["string", "null"], "description": "HH:MM，可空（如仅时段）" },
        "end": { "type": ["string", "null"] },
        "location": { "type": ["string", "null"], "description": "会议室/地点，如 太湖厅AB、大会推荐酒店" },
        "note": { "type": ["string", "null"] },
        "breaks": {
          "description": "块内茶歇等（含起止）。",
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "start": { "type": ["string", "null"] },
              "end": { "type": ["string", "null"] }
            },
            "additionalProperties": false
          }
        },
        "talks": {
          "description": "kind=keynotes 时的主旨报告序列（此层报告通常有独立时间）。",
          "type": "array",
          "items": { "$ref": "#/$defs/talk" }
        },
        "forum_entries": {
          "description": "kind=forums 时，并行论坛与其会议室的列表（引用 forums[].code）。",
          "type": "array",
          "items": {
            "type": "object",
            "required": ["forum_code"],
            "properties": {
              "forum_code": { "type": "string" },
              "room": { "type": ["string", "null"] }
            },
            "additionalProperties": false
          }
        },
        "meetings": {
          "description": "kind=committee_meetings 时的并行会议（各自时间/会议室）。",
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name"],
            "properties": {
              "name": { "$ref": "#/$defs/i18n" },
              "room": { "type": ["string", "null"] },
              "start": { "type": ["string", "null"] },
              "end": { "type": ["string", "null"] }
            },
            "additionalProperties": false
          }
        }
      },
      "additionalProperties": false
    },

    "forum": {
      "description": "技术论坛（一等实体）。内部报告(talks)通常无独立时间，仅继承所属 forum_block 的时间窗。",
      "type": "object",
      "required": ["code", "title"],
      "properties": {
        "code": { "type": "string", "description": "如 CF01" },
        "title": { "$ref": "#/$defs/i18n" },
        "sponsor": { "type": ["string", "null"], "description": "专场赞助商，如 知存科技/阿里巴巴达摩院" },
        "series_part": { "type": ["string", "null"], "description": "系列分场标记，如 “（一）/（二）”" },
        "day_date": { "type": ["string", "null"], "format": "date" },
        "session_period": { "type": ["string", "null"], "enum": ["morning", "afternoon", "evening", null] },
        "room": { "type": ["string", "null"] },
        "description": { "type": ["string", "null"] },
        "chairs": {
          "type": "array",
          "items": { "$ref": "#/$defs/person" }
        },
        "talks": { "type": "array", "items": { "$ref": "#/$defs/talk" } },
        "poster": { "anyOf": [{ "$ref": "#/$defs/asset" }, { "type": "null" }] },
        "detail_extracted": { "type": "boolean", "description": "海报是否已完成视觉解析" },
        "flags": {
          "type": "array",
          "items": { "type": "string" },
          "description": "论坛级数据标注（如源材料间的名称不一致），如实记录不擅自修正"
        }
      },
      "additionalProperties": false
    },

    "talk": {
      "description": "一场报告。用于主旨报告(有时间)与论坛报告(通常无时间)。",
      "type": "object",
      "properties": {
        "order": { "type": ["integer", "null"] },
        "title": { "$ref": "#/$defs/i18n" },
        "title_status": { "$ref": "#/$defs/status" },
        "start": { "type": ["string", "null"], "description": "HH:MM，论坛内报告一般为 null" },
        "end": { "type": ["string", "null"] },
        "speakers": { "type": "array", "items": { "$ref": "#/$defs/person" } },
        "abstract": { "type": ["string", "null"] },
        "abstract_status": { "$ref": "#/$defs/status" },
        "type": { "type": "string", "enum": ["keynote", "invited", "talk", "opening", "other"], "default": "talk" },
        "flags": {
          "type": "array",
          "items": { "type": "string" },
          "description": "数据异常标记，如 “title_abstract_mismatch”（源海报题目与摘要疑似不一致）"
        }
      },
      "additionalProperties": false
    },

    "extraction_meta": {
      "type": "object",
      "properties": {
        "generated_at": { "type": "string" },
        "source": { "type": "string" },
        "forums_total": { "type": "integer" },
        "forums_detail_extracted": { "type": "integer" },
        "notes": { "type": "string" }
      },
      "additionalProperties": true
    }
  }
}
