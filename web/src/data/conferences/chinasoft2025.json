          "talks": [
            {
              "title": {
                "zh": "复杂智能软件系统构造与演化",
                "en": null
              },
              "title_status": "confirmed",
              "start": "09:40",
              "end": "10:20",
              "speakers": [
                {
                  "name": "王怀民",
                  "affiliation_raw": "中国科学院院士",
                  "honorifics": [
                    "中国科学院院士"
                  ],
                  "bio": "王怀民，中国科学院院士，中国计算机学会（CCF）会士，第十四届全国政协委员，CCF开源发展委员会主任，中国软件行业协会理事长，国家百千万人才工程领军人才，教育部科学技术委员会委员。曾获国家杰出青年基金资助，获聘教育部长江学者特聘教授。长期从事分布计算领域研究和人才培养，在分布计算模型、技术与平台方面做出系统性和创造性工作。"
                }
              ],
              "abstract": "以大模型应用系统为代表的智能软件正成为支撑人类社会运转的新型基础设施，报告围绕这类复杂智能软件系统的构造与演化支撑技术展开介绍，提出了智能软件系统开发的“持续演化模型”，并围绕数据工程、模型训练、推理服务、应用开发、可信保障、人机协作等六个主要步骤，分析了每个步骤面临的挑战及潜在技术问题。",
              "abstract_status": "confirmed",
              "type": "keynote"
            },
            {
              "title": {
                "zh": "密态计算：一种蒙着眼睛进行计算的范式",
                "en": null
              },
              "title_status": "confirmed",
              "start": "10:20",
              "end": "11:00",
              "speakers": [
                {
                  "name": "冯登国",
                  "affiliation_raw": "中国科学院院士",
                  "honorifics": [
                    "中国科学院院士"
                  ],
                  "bio": "冯登国，网络与信息安全专家，中国科学院院士。在通信安全、网络安全、可信计算等方面成绩显著，荣获国家科技进步一等奖、国家技术发明二等奖等多项奖励；主持研制了祖冲之（ZUC）算法等多项国际和国家标准。"
                }
              ],
              "abstract": "密态计算是解决开放计算环境下数据安全与隐私保护挑战的关键核心技术，可实现数据的“可用不可见”。本报告介绍密态计算的研究背景，阐述其一般数学模型，概述同态加密、机密计算和联邦学习等三种典型密态计算技术的基本思想及其主要问题和挑战。",
              "abstract_status": "confirmed",
              "type": "keynote"
            },
