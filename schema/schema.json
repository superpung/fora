{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://conf-scheduler/schema/conference.json",
  "title": "Conference Agenda (self-designed)",
  "description": "This project's self-designed, general conference-agenda model. Not compatible with / mapped to any existing format (pretalx / frab / pentabarf). Core: conference -> day -> time block -> forum -> talk; a forum is a first-class entity; a talk may have no time of its own; bilingual and TBD states are supported throughout. The model is a stable core plus an open `extra` escape hatch at each level: when a conference has something the core does not model, it is captured faithfully under `extra` (and/or `flags`) rather than forced into an ill-fitting field or dropped. First-class fields are added by additive schema evolution once a concept recurs.",
  "type": "object",
  "required": ["id", "name", "start_date", "end_date"],
  "properties": {
    "id": { "type": "string", "description": "Unique short conference id, e.g. ccfchip2026" },
    "source_url": { "type": "string" },
    "name": { "$ref": "#/$defs/i18n", "description": "Conference name (zh/en)" },
    "edition": { "type": "string", "description": "Edition, e.g. 第三届" },
    "start_date": { "type": "string", "format": "date" },
    "end_date": { "type": "string", "format": "date" },
    "timezone": { "type": "string", "default": "Asia/Shanghai" },
    "contact": {
      "type": "object",
      "properties": { "email": { "type": "string" } },
      "additionalProperties": true
    },
    "links": {
      "type": "object",
      "description": "Entry points: official site / registration / hotel, etc.",
      "additionalProperties": { "type": "string" }
    },
    "venues": { "type": "array", "items": { "$ref": "#/$defs/venue" } },
    "organizations": { "type": "array", "items": { "$ref": "#/$defs/organization" } },
    "committees": { "type": "array", "items": { "$ref": "#/$defs/committee" } },
    "days": { "type": "array", "items": { "$ref": "#/$defs/day" } },
    "forums": {
      "type": "array",
      "description": "All technical forums (first-class entities). A schedule's forum block references them by code.",
      "items": { "$ref": "#/$defs/forum" }
    },
    "extraction": { "$ref": "#/$defs/extraction_meta" },
    "extra": { "$ref": "#/$defs/extra" }
  },
  "additionalProperties": false,

  "$defs": {
    "i18n": {
      "description": "Bilingual text; zh is required, en is optional.",
      "type": "object",
      "required": ["zh"],
      "properties": {
        "zh": { "type": "string" },
        "en": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },

    "extra": {
      "description": "Escape hatch for conference-specific data the core model does not (yet) represent. An open object: record such data faithfully here instead of forcing it into an ill-fitting field or dropping it. Recurring keys are candidates to promote to first-class fields by additive schema evolution.",
      "type": "object",
      "additionalProperties": true
    },

    "status": {
      "description": "Field certainty: confirmed = fixed; tbd = the source marks it pending (e.g. 待确认/待定); unknown = the source did not provide it.",
      "type": "string",
      "enum": ["confirmed", "tbd", "unknown"]
    },

    "asset": {
      "description": "Reference to a locally downloaded asset.",
      "type": "object",
      "properties": {
        "local_path": { "type": ["string", "null"] },
        "source_url": { "type": ["string", "null"] }
      },
      "additionalProperties": false
    },

    "venue": {
      "type": "object",
      "required": ["id", "name"],
      "properties": {
        "id": { "type": "string" },
        "name": { "$ref": "#/$defs/i18n" },
        "type": { "type": "string", "enum": ["main", "hotel", "other"], "default": "main" },
        "city": { "type": "string" },
        "note": { "type": "string" },
        "extra": { "$ref": "#/$defs/extra" }
      },
      "additionalProperties": false
    },

    "organization": {
      "description": "Host / co-host / supporter / sponsor organization.",
      "type": "object",
      "required": ["name", "role"],
      "properties": {
        "name": { "$ref": "#/$defs/i18n" },
        "role": { "type": "string", "enum": ["host", "co_host", "support", "sponsor"] },
        "sponsor_tier": { "type": ["string", "null"], "description": "Sponsorship tier, e.g. 金钻/钻石/铂金/黄金/白银" },
        "logo": { "$ref": "#/$defs/asset" },
        "extra": { "$ref": "#/$defs/extra" }
      },
      "additionalProperties": false
    },

    "person": {
      "description": "A person. affiliation_raw keeps the source's 'affiliation + title' verbatim; it may optionally be split into structured fields.",
      "type": "object",
      "required": ["name"],
      "properties": {
        "name": { "type": "string" },
        "name_en": { "type": ["string", "null"] },
        "affiliation_raw": { "type": ["string", "null"], "description": "e.g. 南京邮电大学 教授 / 中国科学院院士 深圳大学讲席教授" },
        "organization": { "type": ["string", "null"] },
        "title": { "type": ["string", "null"], "description": "Academic/role title, e.g. 教授/研究员/CEO" },
        "honorifics": { "type": "array", "items": { "type": "string" }, "description": "e.g. 院士/IEEE Fellow" },
        "photo": { "$ref": "#/$defs/asset" },
        "bio": { "type": ["string", "null"] },
        "chair_role": { "type": ["string", "null"], "description": "Role when acting as a forum chair, e.g. 论坛主席/共同主席" },
        "extra": { "$ref": "#/$defs/extra" }
      },
      "additionalProperties": false
    },

    "committee": {
      "description": "A committee / role group, e.g. 大会主席, 程序委员会主席, 大会指导委员会.",
      "type": "object",
      "required": ["role", "members"],
      "properties": {
        "role": { "$ref": "#/$defs/i18n" },
        "ordering_note": { "type": ["string", "null"], "description": "e.g. 按拼音排序" },
        "members": { "type": "array", "items": { "$ref": "#/$defs/person" } },
        "extra": { "$ref": "#/$defs/extra" }
      },
      "additionalProperties": false
    },

    "day": {
      "type": "object",
      "required": ["date", "blocks"],
      "properties": {
        "date": { "type": "string", "format": "date" },
        "venue_id": { "type": ["string", "null"] },
        "overview": {
          "description": "Coarse morning/afternoon/evening labels for this day in the overview matrix (display-only, derivable/redundant).",
          "type": "object",
          "properties": {
            "morning": { "type": "array", "items": { "type": "string" } },
            "afternoon": { "type": "array", "items": { "type": "string" } },
            "evening": { "type": "array", "items": { "type": "string" } }
          },
          "additionalProperties": false
        },
        "blocks": { "type": "array", "items": { "$ref": "#/$defs/block" } },
        "extra": { "$ref": "#/$defs/extra" }
      },
      "additionalProperties": false
    },

    "block": {
      "description": "A time block within a day. kind determines which payload fields apply.",
      "type": "object",
      "required": ["kind"],
      "properties": {
        "id": { "type": "string" },
        "kind": {
          "type": "string",
          "enum": ["registration", "keynotes", "forums", "break", "banquet", "committee_meetings", "other"]
        },
        "title": { "$ref": "#/$defs/i18n" },
        "start": { "type": ["string", "null"], "description": "HH:MM, may be null (e.g. period-only)" },
        "end": { "type": ["string", "null"] },
        "location": { "type": ["string", "null"], "description": "Room/location, e.g. 太湖厅AB, 大会推荐酒店" },
        "note": { "type": ["string", "null"] },
        "breaks": {
          "description": "In-block breaks such as tea breaks (with start/end).",
          "type": "array",
          "items": {
            "type": "object",
            "properties": {
              "name": { "type": "string" },
              "start": { "type": ["string", "null"] },
              "end": { "type": ["string", "null"] }
            },
            "additionalProperties": false
          }
        },
        "talks": {
          "description": "The keynote sequence when kind=keynotes (talks at this level usually have their own time).",
          "type": "array",
          "items": { "$ref": "#/$defs/talk" }
        },
        "forum_entries": {
          "description": "When kind=forums, the parallel forums and their rooms (references forums[].code).",
          "type": "array",
          "items": {
            "type": "object",
            "required": ["forum_code"],
            "properties": {
              "forum_code": { "type": "string" },
              "room": { "type": ["string", "null"] }
            },
            "additionalProperties": false
          }
        },
        "meetings": {
          "description": "When kind=committee_meetings, the parallel meetings (each with its own time/room).",
          "type": "array",
          "items": {
            "type": "object",
            "required": ["name"],
            "properties": {
              "name": { "$ref": "#/$defs/i18n" },
              "room": { "type": ["string", "null"] },
              "start": { "type": ["string", "null"] },
              "end": { "type": ["string", "null"] }
            },
            "additionalProperties": false
          }
        },
        "extra": { "$ref": "#/$defs/extra" }
      },
      "additionalProperties": false
    },

    "forum": {
      "description": "A technical forum (first-class entity). Its talks usually have no time of their own and inherit the enclosing forum block's time window (but a talk may carry its own start/end).",
      "type": "object",
      "required": ["code", "title"],
      "properties": {
        "code": { "type": "string", "description": "e.g. CF01, or a category-coded id like R1/I3" },
        "title": { "$ref": "#/$defs/i18n" },
        "category": {
          "description": "Forum grouping/track, when a conference organizes forums into categories (e.g. 学术论坛/产业论坛/教育论坛/院士峰会). `key` is a stable machine slug; `name` is the display label. Optional — conferences with a single flat forum list omit it.",
          "type": "object",
          "required": ["name"],
          "properties": {
            "key": { "type": ["string", "null"], "description": "stable slug, e.g. academic-forum" },
            "name": { "$ref": "#/$defs/i18n" }
          },
          "additionalProperties": false
        },
        "sponsor": { "type": ["string", "null"], "description": "Session sponsor, e.g. 知存科技/阿里巴巴达摩院" },
        "series_part": { "type": ["string", "null"], "description": "Series-part marker, e.g. （一）/（二）" },
        "day_date": { "type": ["string", "null"], "format": "date" },
        "session_period": { "type": ["string", "null"], "enum": ["morning", "afternoon", "evening", null] },
        "room": { "type": ["string", "null"] },
        "description": { "type": ["string", "null"] },
        "chairs": {
          "type": "array",
          "items": { "$ref": "#/$defs/person" }
        },
        "talks": { "type": "array", "items": { "$ref": "#/$defs/talk" } },
        "poster": { "anyOf": [{ "$ref": "#/$defs/asset" }, { "type": "null" }] },
        "source_url": { "type": ["string", "null"], "description": "Official article-page URL for this forum (e.g. general_NNNN)" },
        "detail_extracted": { "type": "boolean", "description": "Whether the forum's details have been extracted" },
        "flags": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Forum-level data annotations (e.g. inconsistent names across sources), recorded faithfully and not silently corrected"
        },
        "extra": { "$ref": "#/$defs/extra" }
      },
      "additionalProperties": false
    },

    "talk": {
      "description": "A single talk. Used for keynotes (timed) and forum talks (usually untimed).",
      "type": "object",
      "properties": {
        "order": { "type": ["integer", "null"] },
        "title": { "$ref": "#/$defs/i18n" },
        "title_status": { "$ref": "#/$defs/status" },
        "start": { "type": ["string", "null"], "description": "HH:MM; usually null for talks inside a forum" },
        "end": { "type": ["string", "null"] },
        "speakers": { "type": "array", "items": { "$ref": "#/$defs/person" } },
        "abstract": { "type": ["string", "null"] },
        "abstract_status": { "$ref": "#/$defs/status" },
        "type": { "type": "string", "enum": ["keynote", "invited", "talk", "opening", "other"], "default": "talk" },
        "flags": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Data-anomaly markers, e.g. title_abstract_mismatch (source title and abstract appear inconsistent)"
        },
        "extra": { "$ref": "#/$defs/extra" }
      },
      "additionalProperties": false
    },

    "extraction_meta": {
      "type": "object",
      "properties": {
        "generated_at": { "type": "string" },
        "source": { "type": "string" },
        "forums_total": { "type": "integer" },
        "forums_detail_extracted": { "type": "integer" },
        "notes": { "type": "string" }
      },
      "additionalProperties": true
    }
  }
}
